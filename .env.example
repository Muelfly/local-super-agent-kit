# Base local runtime
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODELS_PATH=
LM_STUDIO_APP_PATH=
LM_STUDIO_AUTO_LAUNCH=true
LM_STUDIO_HEALTH_TIMEOUT_MS=45000
LM_STUDIO_MODEL_HINT=nemotron-nano-8b
LM_STUDIO_MODEL_CANDIDATES=
LM_STUDIO_AUTO_ACQUIRE_MODELS=false
LM_STUDIO_AUTO_LOAD_PRIMARY_MODEL=false
LM_STUDIO_PROFILE=4060ti-8b

# Packaged OpenJarvis runtime
OPENJARVIS_ENABLED=true
OPENJARVIS_COMMAND=
OPENJARVIS_BASE_URL=http://127.0.0.1:8000/v1
OPENJARVIS_API_KEY=
OPENJARVIS_STATUS_ARGS=status
OPENJARVIS_SERVE_COMMAND=
OPENJARVIS_MODEL_HINT=

# Packaged OpenClaw runtime behind LM Studio Chat
OPENCLAW_ENABLED=true
OPENCLAW_COMMAND=
OPENCLAW_BASE_URL=http://127.0.0.1:18789/v1
OPENCLAW_API_KEY=
OPENCLAW_MODEL=
OPENCLAW_STATUS_ARGS=gateway status
OPENCLAW_INSTALL_COMMAND=
OPENCLAW_START_COMMAND=

# Packaged NemoClaw sandbox/runtime tail
NEMOCLAW_ENABLED=true
NEMOCLAW_COMMAND=
NEMOCLAW_STATUS_ARGS=status
NEMOCLAW_SETUP_COMMAND=
NEMOCLAW_PROVIDER=ollama
NEMOCLAW_MODEL=qwen2.5:7b
NEMOCLAW_SANDBOX_NAME=local-super-agent
NVIDIA_API_KEY=

# Packaged Hermes runtime
HERMES_ENABLED=true
HERMES_COMMAND=
HERMES_INSTALL_COMMAND=
HERMES_STATUS_ARGS=status --all
HERMES_START_COMMAND=
HERMES_MODEL_HINT=

# Local n8n surface
N8N_ENABLED=true
N8N_BASE_URL=http://127.0.0.1:5678
N8N_START_COMMAND=docker compose -f compose.local.yml up -d n8n
N8N_TOOL_SURFACE_FILE=config/tools/default-surface.json
N8N_GENERATED_SURFACE_FILE=generated/tool-surface.generated.json
N8N_PROMOTE_COMMAND=
N8N_MANAGED_BY_REPO=true
N8N_API_KEY=
N8N_OWNER_EMAIL=
N8N_OWNER_PASSWORD=

# Local control plane
CONTROL_PLANE_ENABLED=true
CONTROL_PLANE_HOST=127.0.0.1
CONTROL_PLANE_PORT=4391
CONTROL_PLANE_BASE_URL=http://127.0.0.1:4391
CONTROL_PLANE_START_COMMAND=node --import tsx src/cli.ts serve-control-plane
RUNTIME_STATE_DIR=.runtime

# Future ingress layer
CHAT_SDK_ENABLED=false
CHAT_SDK_ADAPTERS=discord,github
CHAT_SDK_USER_NAME=local-super-agent
CHAT_SDK_LEDGER_DIR=.runtime/chat-sdk
# Adapter-specific credentials stay in local env only. Let the adapter packages
# auto-detect them, or pass them explicitly in your own framework wrapper later.

# Optional shared surfaces
SHARED_MCP_ENABLED=false
SHARED_MCP_URL=

# Optional OpenJarvis evaluation gate
OPENJARVIS_EVAL_COMMAND=
