{
  "version": 1,
  "tools": [
    {
      "name": "web.fetch",
      "summary": "Fetch a URL through a deterministic webhook lane.",
      "webhookPath": "agent/web-fetch",
      "responseMode": "responseNode",
      "inputSchema": [
        {
          "name": "url",
          "type": "string",
          "required": true,
          "description": "Absolute URL to fetch"
        }
      ]
    },
    {
      "name": "notes.capture",
      "summary": "Capture a durable note request into the local automation lane.",
      "webhookPath": "agent/notes-capture",
      "responseMode": "responseNode",
      "inputSchema": [
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "Short note title"
        },
        {
          "name": "content",
          "type": "string",
          "required": true,
          "description": "Markdown content"
        }
      ]
    },
    {
      "name": "tool.generate",
      "summary": "Generate, validate, and promote a newly generated tool surface.",
      "webhookPath": "agent/tool-generate",
      "responseMode": "responseNode",
      "inputSchema": [
        {
          "name": "name",
          "type": "string",
          "description": "Optional explicit tool name override"
        },
        {
          "name": "webhookPath",
          "type": "string",
          "description": "Optional explicit webhook path override"
        },
        {
          "name": "goal",
          "type": "string",
          "required": true,
          "description": "Desired automation capability"
        }
      ]
    },
    {
      "name": "n8n.workflow.design",
      "summary": "Design an n8n workflow draft and optionally scaffold a local review workflow.",
      "webhookPath": "agent/n8n-workflow-design",
      "responseMode": "responseNode",
      "inputSchema": [
        {
          "name": "goal",
          "type": "string",
          "required": true,
          "description": "Desired workflow outcome"
        },
        {
          "name": "name",
          "type": "string",
          "description": "Optional workflow or tool name override"
        },
        {
          "name": "constraints",
          "type": "array",
          "description": "Optional hard constraints for the workflow draft"
        },
        {
          "name": "promoteToN8n",
          "type": "boolean",
          "description": "Import the generated review workflow into n8n when true"
        }
      ]
    }
  ]
}
